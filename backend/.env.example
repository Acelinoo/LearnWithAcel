# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/learnwithacel"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="your-super-secret-key-change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Password reset ────────────────────────────────────────────────────────────
# How long (minutes) the reset link stays valid
RESET_TOKEN_EXPIRE_MINUTES=15
# Full URL of the frontend reset-password page (token appended as ?token=...)
FRONTEND_RESET_PASSWORD_URL="http://localhost:3000/reset-password"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave MAIL_USERNAME empty to skip sending emails (reset URL printed to console instead)
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_FROM="noreply@learnwithacel.com"
MAIL_FROM_NAME="LearnWithAcel"
MAIL_PORT=587
MAIL_SERVER="smtp.gmail.com"
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,https://learnwithacel.vercel.app,https://learn-with-acel.vercel.app"

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
