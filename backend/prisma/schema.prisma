// Prisma schema for LearnWithAcel backend
// Database: PostgreSQL
// ORM: Prisma (Python via prisma-client-py)

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  full_name         String
  hashed_password   String
  avatar_url        String?
  is_admin          Boolean        @default(false)
  created_at        DateTime       @default(now())

  // Engagement metrics
  xp_total          Int            @default(0)
  current_streak    Int            @default(0)
  longest_streak    Int            @default(0)
  last_activity_at  DateTime?

  // Track the most recent lesson the user opened so the dashboard's
  // "Continue learning" can resume exactly where they left off, even
  // if they haven't marked anything complete yet.
  last_opened_lesson_id String?
  last_opened_at        DateTime?

  progress          UserProgress[]

  @@map("users")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  available   Boolean @default(false)
  role        String
  side        String
  description String
  tasks       String
  techs       Json    // [{ label: String, items: [String] }]
  views       Int     @default(0)
  levels      Level[]

  @@map("categories")
}

model Level {
  id           String   @id @default(uuid())
  category_id  String
  number       Int
  title        String
  slug         String
  subtitle     String
  description  String
  duration     String
  difficulty   String
  accent_color String
  mini_project String
  quiz_count   Int      @default(0)
  base_viewers Int      @default(0)
  views        Int      @default(0)
  tags         Json     // String[]
  coming_soon  Boolean  @default(false)
  lessons      Lesson[]
  category     Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, slug])
  @@map("levels")
}

model Lesson {
  id           String         @id @default(uuid())
  level_id     String
  title        String
  slug         String
  summary      String
  content      String         // Markdown
  duration     String
  base_viewers Int            @default(0)
  views        Int            @default(0)
  order_index  Int
  xp_reward    Int            @default(50)
  is_project   Boolean        @default(false)
  level        Level          @relation(fields: [level_id], references: [id], onDelete: Cascade)
  progress     UserProgress[]

  @@unique([level_id, slug])
  @@map("lessons")
}

model UserProgress {
  id           String    @id @default(uuid())
  user_id      String
  lesson_id    String
  is_completed Boolean   @default(false)
  completed_at DateTime?
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson       Lesson    @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
  @@map("user_progress")
}

/// Universal view-tracking event log.
///
/// Each row is one tracked visit to an entity (lesson, level, category,
/// page, project, …). The event log lets us derive aggregate counters
/// efficiently and build analytics later (top viewed, recent activity,
/// recommendations) without bolting them on per-table.
///
/// `user_id` is nullable — anonymous views are recorded too. `pathname`
/// captures the page that triggered the track call, so a single entity
/// (e.g. a category) can be tracked from multiple touchpoints.
model EntityView {
  id          String   @id @default(uuid())
  entity_type String
  entity_id   String
  user_id     String?
  pathname    String?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([entity_type, created_at])
  @@index([user_id])
  @@map("entity_views")
}
