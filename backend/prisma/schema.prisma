// Prisma schema for LearnWithAcel backend
// Database: PostgreSQL
// ORM: Prisma (Python via prisma-client-py)

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  full_name         String
  hashed_password   String
  avatar_url        String?
  selected_category String?
  selected_role     String?
  is_admin                 Boolean              @default(false)
  has_completed_onboarding Boolean              @default(false)
  created_at               DateTime             @default(now())
  
  // Progress tracking fields
  xp_total                Int      @default(0)
  current_streak          Int      @default(0)
  longest_streak          Int      @default(0)
  last_activity_at        DateTime?
  last_opened_lesson_id   String?
  last_opened_at          DateTime?
  completed_jalur_lessons String?

  progress          UserProgress[]
  reset_tokens      PasswordResetToken[]

  @@map("users")
}

/// One-time token used for the forgot-password flow.
/// Tokens expire after RESET_TOKEN_EXPIRE_MINUTES and are deleted on use.
model PasswordResetToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique  // cryptographically random hex string
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  available   Boolean @default(false)
  role        String
  side        String
  description String
  tasks       String
  techs       Json    // [{ label: String, items: [String] }]
  levels      Level[]

  @@map("categories")
}

model Level {
  id           String   @id @default(uuid())
  category_id  String
  number       Int
  title        String
  slug         String
  subtitle     String
  description  String
  duration     String
  difficulty   String
  accent_color String
  mini_project String
  quiz_count   Int      @default(0)
  base_viewers Int      @default(0)
  tags         Json     // String[]
  coming_soon  Boolean  @default(false)
  lessons      Lesson[]
  category     Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, slug])
  @@map("levels")
}

model Lesson {
  id           String         @id @default(uuid())
  level_id     String
  title        String
  slug         String
  summary      String
  content      String         // Markdown
  duration     String
  base_viewers Int            @default(0)
  order_index  Int
  criteria     Json?          // Array of strings
  hints        String?        // Markdown text
  video_url    String?        // Video embed URL
  level        Level          @relation(fields: [level_id], references: [id], onDelete: Cascade)
  progress     UserProgress[]

  @@unique([level_id, slug])
  @@map("lessons")
}

model UserProgress {
  id           String    @id @default(uuid())
  user_id      String
  lesson_id    String
  is_completed Boolean   @default(false)
  completed_at DateTime?
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson       Lesson    @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
  @@map("user_progress")
}
